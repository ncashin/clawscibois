# Discord
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_USERNAME=slopscibois
# If set, the bot only responds in this channel (and Discord-native threads
# under it). Paste the bare channel snowflake from Discord. Unset = respond
# anywhere the bot is mentioned.
DISCORD_ALLOWED_CHANNEL_ID=
# Used by scripts/clear-discord-commands.ts to also wipe guild-scoped
# slash commands. Bot runtime ignores this; safe to leave unset.
DISCORD_GUILD_ID=

# OpenCode (internal; supervisor spawns opencode serve on :4096)
OPENCODE_SERVER_PASSWORD=
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_URL=http://127.0.0.1:4096
# OpenCode Zen/Go API key (get one at opencode.ai/auth). Required for
# access to Zen and Go models; if unset, opencode falls back to whatever
# providers it can find via other credentials.
OPENCODE_API_KEY=
# Default model for opencode serve. Prefer opencode-go/* for Go-subscription
# models (e.g. opencode-go/kimi-k2.5) or opencode/* for Zen pay-per-use.
OPENCODE_MODEL=opencode-go/kimi-k2.5

# Ports (usually don't need to override)
WEBSITE_PORT=3000
DISCORD_BOT_PORT=3001
