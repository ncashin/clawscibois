# Discord
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_USERNAME=slopscibois
# If set, the bot only responds in this channel (and Discord-native threads
# under it). Paste the bare channel snowflake from Discord. Unset = respond
# anywhere the bot is mentioned.
DISCORD_ALLOWED_CHANNEL_ID=

# OpenCode (internal; supervisor spawns opencode serve on :4096)
OPENCODE_SERVER_PASSWORD=
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_URL=http://127.0.0.1:4096

# Ports (usually don't need to override)
WEBSITE_PORT=3000
DISCORD_BOT_PORT=3001
